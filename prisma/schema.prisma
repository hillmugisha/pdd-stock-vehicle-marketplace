generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Vehicle {
  id               String        @id @default(cuid())
  stockNumber      String        @unique
  partner          String?
  location         String?
  oem              String?
  orderDate        String?
  orderType        String?
  orderNumber      String?
  vin              String?
  year             String?
  pacQid           String?
  specs            String?
  bodyApplication  String?
  color            String?
  salePrice        String?
  targetProduction String?
  orderStatus      String?
  eta              String?
  recalls          String?
  comments         String?
  bodyCode         String?
  fuelType         String?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  reservations     Reservation[]

  @@index([oem])
  @@index([year])
  @@index([color])
  @@index([orderStatus])
  @@index([isActive])
  @@index([pacQid])
  @@index([partner])
}

model SyncLog {
  id          String    @id @default(cuid())
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  inserted    Int       @default(0)
  updated     Int       @default(0)
  inactivated Int       @default(0)
  reactivated Int       @default(0)
  failed      Int       @default(0)
  totalRows   Int       @default(0)
  errors      Json?
  triggeredBy String    @default("scheduler")
  status      String    @default("running")
}

model Reservation {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservedBy  String?
  reservedFor String?
  notes       String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vehicleId])
  @@index([userId])
  @@index([status])
}

model User {
  id           String        @id @default(cuid())
  supabaseId   String        @unique
  email        String        @unique
  name         String?
  company      String?
  role         String        @default("customer")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]
}
